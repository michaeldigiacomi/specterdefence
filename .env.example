# Environment Configuration
# Copy this file to .env and update the values

# Application
APP_NAME=SpecterDefence
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=change-me-in-production-use-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Database
DATABASE_URL=sqlite:///./specterdefence.db

# Microsoft Graph API
MS_GRAPH_API_URL=https://graph.microsoft.com/v1.0
MS_LOGIN_URL=https://login.microsoftonline.com
